[sub_resource type="Shader" id=9]
code = "shader_type canvas_item;

// This is the texture you want to show through the mask
uniform sampler2D mask_texture;

void fragment() {
    COLOR = texture(TEXTURE, UV);
    vec4 value = texture(mask_texture, UV);
    COLOR.a = 1.0 - value.r;
}"

